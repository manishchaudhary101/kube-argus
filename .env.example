# ──────────────────────────────────────────────
# K8SDASH Configuration
# Copy this file to .env and fill in your values
# ──────────────────────────────────────────────

# ── Core ──────────────────────────────────────
PORT=8080
CLUSTER_NAME=my-cluster
# KUBECONFIG=~/.kube/config          # Ignored when running in-cluster

# ── Authentication ───────────────────────────
# Auth mode is auto-detected:
#   • Set GOOGLE_CLIENT_ID  → Google SSO
#   • Set OIDC_ISSUER       → Generic OIDC (Okta, Auth0, Keycloak, Azure AD, Dex)
#   • Set neither           → No login required (everyone gets DEFAULT_ROLE)

# Option A: Google SSO (simplest)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Option B: Generic OIDC
# OIDC_ISSUER=                       # e.g. https://your-org.okta.com/oauth2/default
# OIDC_CLIENT_ID=
# OIDC_CLIENT_SECRET=
# OIDC_ADMIN_GROUP=admin             # OIDC group claim that grants admin role

# ── Roles & Access ──────────────────────────
ADMIN_EMAILS=                         # Comma-separated admin emails (works with any auth mode)
DEFAULT_ROLE=viewer                   # Role when auth is disabled: viewer or admin
SESSION_SECRET=                       # Hex-encoded HMAC key (auto-generated if blank)
SESSION_TTL=8h                        # Session duration (Go duration: 1h, 30m, 24h)
# INSECURE_COOKIE=true               # Set for HTTP-only dev environments

# ── CORS ──────────────────────────────────────
# CORS_ORIGIN=https://mydashboard.example.com  # Restrict Access-Control-Allow-Origin (default: *)

# ── Prometheus Metrics ───────────────────────
# Leave blank to disable metrics panels
PROMETHEUS_URL=                       # e.g. http://prometheus:9090 or https://prom-xxx.grafana.net
PROMETHEUS_USER=                      # Basic auth username (Grafana Cloud: numeric user ID)
PROMETHEUS_KEY=                       # Basic auth password / API key

# ── AI Diagnosis (Optional) ─────────────────
# Any OpenAI-compatible chat completions API
LLM_GATEWAY_URL=                      # e.g. https://api.openai.com/v1/chat/completions
LLM_GATEWAY_KEY=                      # Bearer token
LLM_GATEWAY_MODEL=                    # e.g. gpt-4o, claude-3-sonnet

# ── AWS (Optional) ──────────────────────────
# For Secrets Manager config loading and spot pricing
AWS_SECRET_NAME=                      # Secrets Manager secret ID (leave blank to skip)
AWS_REGION=us-east-1
# AWS_DEFAULT_REGION=us-east-1
