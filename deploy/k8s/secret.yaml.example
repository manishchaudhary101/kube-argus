# Copy this to secret.yaml and fill in your values
# kubectl apply -f secret.yaml
apiVersion: v1
kind: Secret
metadata:
  name: kube-argus-config
  namespace: kube-argus
type: Opaque
stringData:
  # ── Google SSO (Option A) ──────────────────
  # GOOGLE_CLIENT_ID: ""
  # GOOGLE_CLIENT_SECRET: ""

  # ── Generic OIDC (Option B) ────────────────
  # OIDC_ISSUER: ""
  # OIDC_CLIENT_ID: ""
  # OIDC_CLIENT_SECRET: ""
  # OIDC_ADMIN_GROUP: "admin"

  # ── Roles & Access ────────────────────────
  ADMIN_EMAILS: ""
  DEFAULT_ROLE: "viewer"
  SESSION_SECRET: ""
  SESSION_TTL: "8h"

  # ── Prometheus ─────────────────────────────
  PROMETHEUS_URL: ""
  PROMETHEUS_USER: ""
  PROMETHEUS_KEY: ""

  # ── AI (Optional) ─────────────────────────
  LLM_GATEWAY_URL: ""
  LLM_GATEWAY_KEY: ""
  LLM_GATEWAY_MODEL: ""

  # ── AWS (Optional) ─────────────────────────
  AWS_SECRET_NAME: ""
  AWS_REGION: "us-east-1"
